{
  "name": "@lerna-lite/core",
  "version": "5.1.0",
  "description": "Lerna-Lite core implementation module",
  "homepage": "https://github.com/lerna-lite/lerna-lite",
  "bugs": {
    "url": "https://github.com/lerna-lite/lerna-lite/issues"
  },
  "license": "MIT",
  "author": "Ghislain B.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lerna-lite/lerna-lite.git",
    "directory": "packages/core"
  },
  "funding": {
    "type": "ko_fi",
    "url": "https://ko-fi.com/ghiscoding"
  },
  "files": [
    "/dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "remove dist && tsgo",
    "build:incremental": "tsgo --incremental --sourceMap false --excludeDirectories dist",
    "echo:test": "echo \"Lerna-Lite core package\"",
    "pack-tarball": "npm pack"
  },
  "dependencies": {
    "@inquirer/expand": "^5.0.12",
    "@inquirer/input": "^5.0.11",
    "@inquirer/select": "^5.1.3",
    "@lerna-lite/npmlog": "workspace:*",
    "@npmcli/run-script": "^10.0.4",
    "ci-info": "catalog:",
    "dedent": "catalog:",
    "fs-extra": "catalog:",
    "json5": "^2.2.3",
    "lilconfig": "^3.1.3",
    "load-json-file": "catalog:dependencies",
    "npm-package-arg": "catalog:",
    "p-map": "catalog:",
    "p-queue": "^9.1.2",
    "semver": "catalog:",
    "tinyexec": "catalog:dependencies",
    "tinyglobby": "catalog:dependencies",
    "write-file-atomic": "^7.0.1",
    "write-json-file": "catalog:dependencies",
    "yaml": "catalog:dependencies",
    "zeptomatch": "catalog:dependencies"
  },
  "devDependencies": {
    "@types/dedent": "catalog:devDependencies",
    "@types/fs-extra": "catalog:devDependencies",
    "@types/inquirer": "^9.0.9",
    "@types/npm-package-arg": "catalog:devDependencies",
    "@types/semver": "catalog:devDependencies",
    "@types/write-file-atomic": "^4.0.3",
    "@types/yargs-parser": "catalog:devDependencies",
    "npm-registry-fetch": "catalog:",
    "yargs": "catalog:dependencies",
    "yargs-parser": "catalog:devDependencies"
  },
  "engines": {
    "node": "^22.17.0 || >=24.0.0"
  }
}
