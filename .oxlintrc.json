{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "oxc", "typescript", "vitest", "unicorn"],
  "jsPlugins": ["eslint-plugin-local-import-ext"],
  "env": {
    "es2025": true,
    "node": true,
    "shared-node-browser": true
  },
  "ignorePatterns": ["**/*.{js,mjs,json,md}", "**/*/*.d.ts", "**/dist/*", "**/__helpers__/**/*.*", "**/__mocks__/**/*.*"],
  "rules": {
    // typescript-eslint rules are not all implemented yet, see https://github.com/oxc-project/oxc/issues/2180
    "typescript/ban-ts-comment": "off",
    "typescript/consistent-type-definitions": "error",
    "typescript/consistent-type-exports": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/no-empty-function": "off",
    "typescript/no-empty-object-type": ["error", { "allowInterfaces": "with-single-extends" }],
    "typescript/no-explicit-any": "off",
    "typescript/no-inferrable-types": "error",
    "typescript/no-unsafe-function-type": "off",
    "typescript/no-non-null-assertion": "off",
    "typescript/no-unused-expressions": "off",
    "typescript/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "caughtErrors": "none"
      }
    ],

    // "import/extensions" rule is blocked by https://github.com/oxc-project/oxc/issues/19431
    // use custom "eslint-plugin-import-ext" custom eslint plugin in the meantime to catch any missing local import file extensions
    "import/extensions": "off",
    "local-import-ext/require-local-extension": [
      "error",
      {
        "js": "always",
        "ts": "never",
        "excludedFolders": ["demos/aurelia/test", "demos/react/test", "demos/vue/test", "frameworks/angular-slickgrid", "test"]
      }
    ],
    "import/no-self-import": "error",

    // Unicorn rules
    "unicorn/no-empty-file": "off",
    "unicorn/no-new-array": "off",
    "unicorn/prefer-node-protocol": "error",

    // vitest rules
    "vitest/prefer-snapshot-hint": "off",
    "vitest/no-conditional-expect": "off",
    "vitest/no-standalone-expect": "off",
    "vitest/require-mock-type-parameters": "off",
    "vitest/valid-expect": "error",

    // Additional rules
    "no-async-promise-executor": "off",
    "oxc/erasing-op": "off",
    "curly": ["error", "all"],
    "object-shorthand": "error",

    // type aware rules
    "typescript/no-array-delete": "off",
    "typescript/no-misused-spread": "off",
    "typescript/prefer-optional-chain": "error",
    "typescript/require-array-sort-compare": "off"
  },
  "overrides": [
    {
      "files": ["**/*.spec.*", "**/__tests__/**", "**/__mocks__/**", "**/__fixtures__/**"],
      "rules": {
        "curly": "off"
      }
    }
  ]
}
