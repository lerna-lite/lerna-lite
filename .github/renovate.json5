{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:base', 'group:allNonMajor'],
  dependencyDashboard: true,
  labels: ['📦 dependencies', '🤖 bot'],
  minimumReleaseAge: '2 days',
  // since all PRs touches the pnpm lock file, let's open not more than 2 PRs at the same time
  prConcurrentLimit: 2,
  rangeStrategy: 'bump',
  packageRules: [
    {
      depTypeList: ['peerDependencies'],
      enabled: false,
    },
    {
      // group all Conventional-Changelog dependencies
      matchPackagePatterns: ['^conventional-', '^@conventional-changelog/'],
      groupName: 'Conventional-Changelog packages',
    },
    {
      // group all Inquirer dependencies
      matchPackagePatterns: ['^@inquirer/'],
      groupName: 'Inquirer packages',
    },
    {
      matchManagers: ['github-actions'],
      matchDepNames: ['pnpm/action-setup'],
      allowedVersions: '< 6.0.0',
      description: 'Keep pnpm action at v5 until we migrate to pnpm v11',
    },
    // postponed the following npm packages to next major, since they now require NodeJS: ^22.22.2 || ^24.15.0 || >=26.0.0
    {
      packageNames: ['npm-package-arg', 'ssri'],
      allowedVersions: '< 14.0.0',
    },
    {
      packageNames: ['@npmcli/run-script', 'npm-packlist'],
      allowedVersions: '< 11.0.0',
    },
    {
      packageNames: ['npm-registry-fetch'],
      allowedVersions: '< 20.0.0',
    },
    {
      packageNames: ['@npmcli/package-json', 'write-file-atomic'],
      allowedVersions: '< 8.0.0',
    },
    {
      packageNames: ['pacote'],
      allowedVersions: '< 22.0.0',
    },
  ],
  ignoreDeps: ['node', 'pnpm'],
  ignorePaths: ['helpers', '**/__fixtures__/**', '**/__mocks__/**', '**/fixtures/**', '**/mocks/**'],
  schedule: ['every 2 months on Thursday'],
}
